pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        SONAR_ORG = 'aymanprojects0'
        SONAR_PROJECT_KEY = 'aymanprojects0_Jenkins-Zero-To-Hero'
        DOCKER_IMAGE = "spring-boot-app:${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/aymanprojects0/Jenkins-Zero-To-Hero.git'
            }
        }

        stage('Build & Unit Tests') {
            steps {
                dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
                    sh 'mvn clean package'
                }
            }
            post {
                always {
                    junit 'java-maven-sonar-argocd-helm-k8s/spring-boot-app/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarCloud Analysis') {
            steps {
                dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
                    withCredentials([string(credentialsId: 'sonarcloud-token', variable: 'SONAR_TOKEN')]) {
                        sh """
                          mvn sonar:sonar \
                            -Dsonar.organization=${SONAR_ORG} \
                            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                            -Dsonar.host.url=https://sonarcloud.io \
                            -Dsonar.login=${SONAR_TOKEN}
                        """
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
                    sh "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline terminé avec succès : build, tests, analyse SonarCloud et image Docker créée.'
        }
        failure {
            echo 'Le pipeline a échoué — vérifier les logs de la stage concernée.'
        }
    }
}
